# ============================================
# FISHFLOW - ENVIRONMENT VARIABLES
# ============================================

# App
NODE_ENV=development
APP_NAME=FishFlow
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fishflow
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=change_this_to_random_string
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_this_to_another_random_string

# VK API
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret
VK_SERVICE_KEY=your_vk_service_key
VK_CALLBACK_SECRET=your_callback_secret

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# AI / LLM
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# YandexGPT (for Russian specific)
YANDEX_GPT_API_KEY=your_yandex_key
YANDEX_GPT_FOLDER_ID=your_folder_id

# Payment
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_START_PRICE_ID=price_start_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_EXPERT_PRICE_ID=price_expert_monthly

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@fishflow.com

# Storage (Yandex Cloud / AWS)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=fishflow-assets
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Monitoring
SENTRY_DSN=your_sentry_dsn

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Tenant
DEFAULT_TENANT=nutrition
