# ============================================
# FISHFLOW - ENVIRONMENT VARIABLES
# Copy to .env and fill in real values for local dev.
# In production all secrets come from the host (Render).
# ============================================

# App
NODE_ENV=development
ENVIRONMENT=development            # development | staging | production
APP_NAME=FishFlow
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fishflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
# Set to "true" to skip Base.metadata.create_all + default-tenant seed at
# startup. Useful when the API runs against an existing schema (managed
# by Alembic / shared with another project).
SKIP_DB_BOOTSTRAP=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Auth — REQUIRED in staging/production. Generate with `openssl rand -hex 32`.
JWT_SECRET=
JWT_EXPIRES_IN=7
REFRESH_TOKEN_SECRET=

# NextAuth (web app) — REQUIRED in production
# NEXTAUTH_SECRET: openssl rand -hex 32
# NEXTAUTH_URL: public URL of the web app (e.g. https://app.fishflow.ru)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Frontend → API base URL (must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEBUG=false

# Public site URL (used by SEO, sitemap and OG image)
NEXT_PUBLIC_SITE_URL=https://assistent-cf91.onrender.com

# Optional: Plausible Analytics domain (script is injected only when set)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# VK API
VK_APP_ID=
VK_APP_SECRET=
VK_SERVICE_KEY=
VK_CALLBACK_SECRET=
VK_API_VERSION=5.199

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# AI / LLM — REQUIRED for content/audit endpoints
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# YandexGPT (optional)
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_START_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_EXPERT_PRICE_ID=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@fishflow.com

# Storage (S3-compatible, e.g. Yandex Cloud Object Storage)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=fishflow-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Monitoring
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Tenant
DEFAULT_TENANT=nutrition
CORS_ORIGINS=["http://localhost:3000","https://app.fishflow.ru","https://fishflow.ru"]
